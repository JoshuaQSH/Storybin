DATABASE_URL=
ADMIN_TOKEN=change-me

# Use database for local development, or r2 for object storage-backed novel caching.
CACHE_STORAGE_BACKEND=database

# R2 / S3-compatible object storage settings.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_KEY_PREFIX=novels
# Optional override. Leave blank for the default jurisdiction endpoint.
R2_ENDPOINT_URL=

# Crawler settings.
FETCH_BACKENDS=requests
INDEX_MAX_PAGES=0
RATE_LIMIT_SECONDS=1.5
